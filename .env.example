# Required: Cursor API key (user or team service account)
# https://cursor.com/dashboard/cloud-agents
CURSOR_API_KEY=cursor_...

# Server
PORT=3000
HOST=0.0.0.0

# Root directory containing cloned repositories the server can operate on.
# Bare-metal / npm: default REPOS_ROOT=./repos (relative to process cwd).
# Docker Compose: set REPOS_ROOT=/data/repos via compose environment (volume mount); do not rely on this file alone in containers.
REPOS_ROOT=./repos

# Default model for local agent runs
CURSOR_MODEL=composer-2
